# Supabase (영업 메일링 프로젝트)
# .env.example을 복사해 .env 파일을 만들고 값을 채워주세요.

# Supabase 프로젝트 URL (대시보드 > Settings > API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anon Key (공개 키, 클라이언트용)
SUPABASE_ANON_KEY=your-anon-key

# 크롤러가 brands에 insert 하려면 필요 (RLS 우회). 대시보드와 동일한 service_role 키.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Edge Function 'generate-proposals'용 (Supabase Secrets에 설정 권장)
# GEMINI_API_KEY=your-gemini-api-key

# Step 3: 메일 발송 (send-proposal-emails) - Supabase Edge Function Secrets에 설정
# RESEND_API_KEY=re_xxxx
# RESEND_FROM_EMAIL=notify@yourdomain.com

# 제안서 상세보기 클릭 후 리다이렉트 URL (proposal-viewed 웹훅)
# PROPOSAL_VIEWED_REDIRECT_URL=https://your-site.com/thank-you
